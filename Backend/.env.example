APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Windows / FE Costa Rica: ruta al openssl.exe si PHP (Apache, etc.) no ve el PATH del sistema
# OPENSSL_BIN="C:\Program Files\OpenSSL-Win64\bin\openssl.exe"

# Opcional: API pública Hacienda CR (proxy CAT/CABYS). Por defecto se usa https://api.hacienda.go.cr y TTL en config/services.php
# Si Hacienda devuelve HTML de bloqueo, probar User-Agent tipo navegador (ver default en config/services.php)
# HACIENDA_CR_USER_AGENT=Mozilla/5.0 ...
# HACIENDA_CR_API_BASE_URL=https://api.hacienda.go.cr
# HACIENDA_CR_CACHE_CABYS_CODIGO=21600
# HACIENDA_CR_CACHE_CABYS_Q=3600
# HACIENDA_CR_CACHE_CONTRIBUYENTE=43200
