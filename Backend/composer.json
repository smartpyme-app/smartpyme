{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "aws/aws-sdk-php": "^3.337",
        "barryvdh/laravel-dompdf": "^3.0",
        "cweagans/composer-patches": "^2.0",
        "dazza-dev/dgt-cr": "^1.0",
        "dazza-dev/laravel-dgt-cr": "1.0",
        "doctrine/dbal": "^3.9",
        "guzzlehttp/guzzle": "^7.0.1",
        "intervention/image": "^2.7",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.0",
        "luecano/numero-a-letras": "^2.0",
        "maatwebsite/excel": "^3.1",
        "mpdf/mpdf": "^8.2",
        "nesbot/carbon": "^3.0",
        "php-open-source-saver/jwt-auth": "^2.0",
        "picqer/php-barcode-generator": "^3.2",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "spatie/laravel-permission": "^6.0"
    },
    "require-dev": {
        "spatie/laravel-ignition": "^2.0",
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.3.1",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^11.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "audit": {
            "block-insecure": false
        },
        "allow-plugins": {
            "cweagans/composer-patches": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "patches": {
            "dazza-dev/dgt-xml-generator": {
                "FE CR: XSD v4.4 — decimales, ImpuestoAsumidoEmisorFabrica siempre antes de ImpuestoNeto, taxes snake/camel (Emisor/Receptor antes de CondicionVenta)": "patches/dgt-xml-generator-fe-cr-xsd-v44.patch",
                "FE CR: LineaDetalle — Detalle antes de TipoTransaccion (tiqueteElectronico / facturaElectronico v4.4)": "patches/dgt-xml-generator-linea-detalle-detalle-antes-tipo-transaccion.patch",
                "FE CR: Tiquete — líneas sin TipoTransaccion (v4.4; plantilla items-ticket)": "patches/dgt-xml-generator-tiquete-lineas-sin-tipo-transaccion.patch",
                "FE CR: Factura electrónica de compras (08, FacturaElectronicaCompra v4.4)": "patches/dgt-xml-generator-fec-factura-electronica-compra.patch",
                "FE CR: FEC — createDocument() compatible con BaseDocumentBuilder (PurchaseInvoice en unión de tipos)": "patches/dgt-xml-generator-fec-base-document-builder-return-type.patch",
                "FE CR: FEC — CodigoActividadReceptor obligatorio en info.xml (tipo 08; minLength XSD)": "patches/dgt-xml-generator-info-fec-codigo-actividad-receptor.patch",
                "FE CR: FEC LineaDetalle — orden XSD facturaElectronicaCompra (PrecioUnitario/MontoTotal antes de TipoTransaccion; plantilla items-fec)": "patches/dgt-xml-generator-fec-linea-detalle-xsd-orden.patch"
            }
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
