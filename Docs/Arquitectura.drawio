        <mxCell id="AHCUfWhOA-wSP3EiWypV-16" value="&lt;h1&gt;Angular&lt;/h1&gt;&lt;p&gt;El frontend de la aplicación está construido en Angular, un framework de JavaScript para el desarrollo de interfaces de usuario. Además se usa Bootstrap como sistema de diseño.&lt;br&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="1734.88" y="160" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="AHCUfWhOA-wSP3EiWypV-17" value="&lt;h1&gt;Navegador&amp;nbsp;&lt;br&gt;&lt;/h1&gt;&lt;p&gt;Los usuarios interactúan con la aplicación a través de un navegador web.&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="1734.88" y="40" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="AHCUfWhOA-wSP3EiWypV-19" value="&lt;h1&gt;API RESTful&lt;br&gt;&lt;/h1&gt;&lt;p&gt;La&lt;span style=&quot;background-color: initial;&quot;&gt;&amp;nbsp;API proporciona una interfaz para que el frontend pueda realizar solicitudes al servidor.&lt;/span&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="1734.88" y="306" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="AHCUfWhOA-wSP3EiWypV-21" value="&lt;h1&gt;Laravel&amp;nbsp;&lt;br&gt;&lt;/h1&gt;&lt;p&gt;El backend de la aplicación está construido en Laravel, un popular framework de PHP para el desarrollo de aplicaciones web.&lt;/p&gt;&lt;p&gt;&amp;nbsp;Laravel maneja la lógica de negocio, la autenticación, la gestión de bases de datos y otras operaciones del servidor.&lt;br&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="1734.88" y="466" width="240" height="164" as="geometry" />
        </mxCell>
        <mxCell id="AHCUfWhOA-wSP3EiWypV-24" value="&lt;h1&gt;MySQL&amp;nbsp;&lt;br&gt;&lt;/h1&gt;&lt;p&gt;La aplicación utiliza MySQL para almacenar y recuperar datos. Laravel se encarga de interactuar con la base de datos.&lt;br&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="1740" y="705.5" width="240" height="114.5" as="geometry" />
        </mxCell>
